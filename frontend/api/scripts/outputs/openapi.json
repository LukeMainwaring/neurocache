    "/api/knowledge-sources/{source_id}/ingest": {
      "post": {
        "tags": [
          "knowledge-sources"
        ],
        "summary": "Ingest Document",
        "description": "Ingest a single document from a knowledge source.\n\nArgs:\n    source_id: The knowledge source ID\n    relative_path: Path relative to knowledge source root (e.g., \"Brain Dump.md\")",
        "operationId": "ingestDocument",
        "parameters": [
          {
            "name": "source_id",
            "in": "path",
            "required": true,
            "schema": {
              "type": "string",
              "format": "uuid",
              "title": "Source Id"
            }
          },
          {
            "name": "relative_path",
            "in": "query",
            "required": true,
            "schema": {
              "type": "string",
              "title": "Relative Path"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Successful Response",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/DocumentSchema"
                }
              }
            }
          },
          "422": {
            "description": "Validation Error",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/HTTPValidationError"
                }
              }
            }
          }
        }
      }
    },
    "/api/knowledge-sources/{source_id}/ingest-all": {
      "post": {
        "tags": [
          "knowledge-sources"
        ],
        "summary": "Ingest All Documents",
        "description": "Ingest all markdown documents from a knowledge source.\n\nDiscovers all .md files in the vault (excluding system directories like .obsidian)\nand ingests them into the database with embeddings.\n\nArgs:\n    source_id: The knowledge source ID\n    force_reindex: If True, re-ingest documents even if already indexed",
        "operationId": "ingestAllDocuments",
        "parameters": [
          {
            "name": "source_id",
            "in": "path",
            "required": true,
            "schema": {
              "type": "string",
              "format": "uuid",
              "title": "Source Id"
            }
          },
          {
            "name": "force_reindex",
            "in": "query",
            "required": false,
            "schema": {
              "type": "boolean",
              "default": false,
              "title": "Force Reindex"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Successful Response",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/BatchIngestResult"
                }
              }
            }
          },
          "422": {
            "description": "Validation Error",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/HTTPValidationError"
                }
              }
            }
          }
        }
      }
    },
