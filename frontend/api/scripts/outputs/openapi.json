  "components": {
    "schemas": {
      "BatchIngestFailure": {
        "properties": {
          "relative_path": {
            "type": "string",
            "title": "Relative Path",
            "description": "Path relative to source root"
          },
          "error": {
            "type": "string",
            "title": "Error",
            "description": "Error message"
          }
        },
        "type": "object",
        "required": [
          "relative_path",
          "error"
        ],
        "title": "BatchIngestFailure",
        "description": "Details about a single file that failed to ingest."
      },
      "BatchIngestResult": {
        "properties": {
          "total_files_found": {
            "type": "integer",
            "title": "Total Files Found",
            "description": "Total .md files discovered"
          },
          "documents_created": {
            "type": "integer",
            "title": "Documents Created",
            "description": "New documents successfully ingested"
          },
          "documents_skipped": {
            "type": "integer",
            "title": "Documents Skipped",
            "description": "Already indexed, skipped"
          },
          "documents_failed": {
            "type": "integer",
            "title": "Documents Failed",
            "description": "Failed to ingest"
          },
          "failed_files": {
            "items": {
              "$ref": "#/components/schemas/BatchIngestFailure"
            },
            "type": "array",
            "title": "Failed Files"
          },
          "duration_seconds": {
            "type": "number",
            "title": "Duration Seconds",
            "description": "Total processing time"
          }
        },
        "type": "object",
        "required": [
          "total_files_found",
          "documents_created",
          "documents_skipped",
          "documents_failed",
          "duration_seconds"
        ],
        "title": "BatchIngestResult",
        "description": "Result of a batch ingestion operation."
      },
      "DocumentSchema": {
        "properties": {
          "id": {
            "type": "string",
            "format": "uuid",
            "title": "Id",
            "description": "Unique identifier"
          },
          "knowledge_source_id": {
            "type": "string",
            "format": "uuid",
            "title": "Knowledge Source Id",
            "description": "Parent knowledge source ID"
          },
          "relative_path": {
            "type": "string",
            "title": "Relative Path",
            "description": "Path relative to source root"
          },
          "title": {
            "anyOf": [
              {
                "type": "string"
              },
              {
                "type": "null"
              }
            ],
            "title": "Title",
            "description": "Extracted document title"
          },
          "content_hash": {
            "type": "string",
            "title": "Content Hash",
            "description": "SHA-256 hash for change detection"
          },
          "file_modified_at": {
            "anyOf": [
              {
                "type": "string",
                "format": "date-time"
              },
              {
                "type": "null"
              }
            ],
            "title": "File Modified At",
            "description": "Filesystem mtime"
          },
          "status": {
            "$ref": "#/components/schemas/DocumentStatus",
            "description": "Indexing status"
          },
          "error_message": {
            "anyOf": [
              {
                "type": "string"
              },
              {
                "type": "null"
              }
            ],
            "title": "Error Message",
            "description": "Error details if failed"
          },
          "chunk_count": {
            "type": "integer",
            "title": "Chunk Count",
            "description": "Number of chunks created"
          },
          "doc_metadata": {
            "anyOf": [
              {
                "additionalProperties": true,
                "type": "object"
              },
              {
                "type": "null"
              }
            ],
            "title": "Doc Metadata",
            "description": "Frontmatter, tags, links"
          },
          "created_at": {
            "type": "string",
            "format": "date-time",
            "title": "Created At",
            "description": "Creation timestamp"
          },
          "updated_at": {
            "type": "string",
            "format": "date-time",
            "title": "Updated At",
            "description": "Last update timestamp"
          },
          "indexed_at": {
            "anyOf": [
              {
                "type": "string",
                "format": "date-time"
              },
              {
                "type": "null"
              }
            ],
            "title": "Indexed At",
            "description": "When embedding completed"
          }
        },
        "type": "object",
        "required": [
          "id",
          "knowledge_source_id",
          "relative_path",
          "content_hash",
          "status",
          "chunk_count",
          "created_at",
          "updated_at"
        ],
        "title": "DocumentSchema",
        "description": "Full document response schema."
      },
      "DocumentStatus": {
        "type": "string",
        "enum": [
          "pending",
          "processing",
          "indexed",
          "error",
          "deleted"
        ],
        "title": "DocumentStatus",
        "description": "Status of a document in the indexing pipeline."
      },
      "HTTPValidationError": {
        "properties": {
          "detail": {
            "items": {
              "$ref": "#/components/schemas/ValidationError"
            },
            "type": "array",
            "title": "Detail"
          }
        },
        "type": "object",
        "title": "HTTPValidationError"
      },
      "HealthCheckResponse": {
        "properties": {
          "status": {
            "type": "string",
            "title": "Status"
          }
        },
        "type": "object",
        "required": [
          "status"
        ],
        "title": "HealthCheckResponse"
      },
      "KnowledgeSourceCreateSchema": {
        "properties": {
          "source_type": {
            "$ref": "#/components/schemas/KnowledgeSourceType",
            "description": "Type of knowledge source"
          },
          "name": {
            "type": "string",
            "title": "Name",
            "description": "User-friendly display name"
          },
          "file_path": {
            "anyOf": [
              {
                "type": "string"
              },
              {
                "type": "null"
              }
            ],
            "title": "File Path",
            "description": "Local filesystem path"
          }
        },
        "type": "object",
        "required": [
          "source_type",
          "name"
        ],
        "title": "KnowledgeSourceCreateSchema",
        "description": "Schema for creating a knowledge source."
      },
      "KnowledgeSourceListResponse": {
        "properties": {
          "sources": {
            "items": {
              "$ref": "#/components/schemas/KnowledgeSourceSchema"
            },
            "type": "array",
            "title": "Sources",
            "description": "List of knowledge sources"
          }
        },
        "type": "object",
        "required": [
          "sources"
        ],
        "title": "KnowledgeSourceListResponse",
        "description": "Response schema for listing knowledge sources."
      },
      "KnowledgeSourceSchema": {
        "properties": {
          "id": {
            "type": "string",
            "format": "uuid",
            "title": "Id",
            "description": "Unique identifier"
          },
          "user_id": {
            "type": "string",
            "title": "User Id",
            "description": "Owner user ID"
          },
          "source_type": {
            "$ref": "#/components/schemas/KnowledgeSourceType",
            "description": "Type of knowledge source"
          },
          "name": {
            "type": "string",
            "title": "Name",
            "description": "User-friendly display name"
          },
          "file_path": {
            "anyOf": [
              {
                "type": "string"
              },
              {
                "type": "null"
              }
            ],
            "title": "File Path",
            "description": "Local filesystem path"
          },
          "status": {
            "$ref": "#/components/schemas/KnowledgeSourceStatus",
            "description": "Connection status"
          },
          "last_synced_at": {
            "anyOf": [
              {
                "type": "string",
                "format": "date-time"
              },
              {
                "type": "null"
              }
            ],
            "title": "Last Synced At",
            "description": "Last sync time"
          },
          "error_message": {
            "anyOf": [
              {
                "type": "string"
              },
              {
                "type": "null"
              }
            ],
            "title": "Error Message",
            "description": "Error details if any"
          },
          "config": {
            "anyOf": [
              {
                "additionalProperties": true,
                "type": "object"
              },
              {
                "type": "null"
              }
            ],
            "title": "Config",
            "description": "Source-specific config"
          },
          "created_at": {
            "type": "string",
            "format": "date-time",
            "title": "Created At",
            "description": "Creation timestamp"
          },
          "updated_at": {
            "type": "string",
            "format": "date-time",
            "title": "Updated At",
            "description": "Last update timestamp"
          }
        },
        "type": "object",
        "required": [
          "id",
          "user_id",
          "source_type",
          "name",
          "status",
          "created_at",
          "updated_at"
        ],
        "title": "KnowledgeSourceSchema",
        "description": "Full knowledge source response schema."
      },
      "KnowledgeSourceStatus": {
        "type": "string",
        "enum": [
          "pending",
          "connected",
          "syncing",
          "error"
        ],
        "title": "KnowledgeSourceStatus",
        "description": "Status of a knowledge source."
      },
      "KnowledgeSourceType": {
        "type": "string",
        "enum": [
          "obsidian",
          "notion",
          "local_folder"
        ],
        "title": "KnowledgeSourceType",
        "description": "Type of knowledge source."
      },
      "KnowledgeSourceUpdateSchema": {
        "properties": {
          "name": {
            "anyOf": [
              {
                "type": "string"
              },
              {
                "type": "null"
              }
            ],
            "title": "Name",
            "description": "User-friendly display name"
          },
          "file_path": {
            "anyOf": [
              {
                "type": "string"
              },
              {
                "type": "null"
              }
            ],
            "title": "File Path",
            "description": "Local filesystem path"
          }
        },
        "type": "object",
        "title": "KnowledgeSourceUpdateSchema",
        "description": "Schema for updating a knowledge source."
      },
      "MessageMetadata": {
        "properties": {
